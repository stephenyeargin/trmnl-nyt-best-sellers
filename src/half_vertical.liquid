{% if display == 'list' %}
<div class="layout layout--row">
  <div class="w--full" style="column-count: 1">
    {% for book in books limit: 10 %}
    <div class="item mb--1 lg:mb--6">
      <div class="meta w--5 lg:w--10">
    <span class="label label--small lg:label--large text-stroke">{{ book.rank }}</span>
      </div>
      <div class="content flex flex--row flex--stretch align--middle gap--medium">
        <div class="">
          <div><span class="label label--small lg:label--base label--underline" data-clamp="1">{{ book.title }}</span></div>
          <div>
            <span class="description description--base lg:description--large">
              {{ book.contributor }}
              {% if book.asterisk != 0 %}*{% endif %}
              {% if book.dagger != 0 %}&dagger;{% endif %}
            </span>
          </div>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{% if display == 'covers' %}
<div class="layout layout--row">
  <div class="grid grid--cols-2 gap--medium lg:gap--large">
  {% for book in books limit: 4 %}
    <div class="flex flex--column align--middle justify--center text--center" style="position:relative;">
      <img src="{{ book.book_image }}" class="image image-dither w--32 lg:w--56" style="object-fit: cover; filter: grayscale(1) contrast(1.2) brightness(1.1) saturate(0.8);" />
      <div style="position: absolute; bottom: 2px; right: 12px;"><span class="label label--small label--inverted h--5" style="border: solid 2px #ffffff;">#{{ book.rank }}</span></div>
    </div>
  {% endfor %}
  </div>
</div>
{% endif %}

<div class="title_bar">
  <img class="image image-stroke" src="data:image/svg+xml;base64,{{ nyt_svg |  base64_encode }}" />
  <span class="title">{{ list }} for {{ list_date | date: '%B %-d, %Y' }}</span>
</div>
